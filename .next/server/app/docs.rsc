8:["$","div",null,{"className":"prose prose-invert max-w-none","children":[["$","p",null,{"className":"text-gray-400 text-lg mb-8 leading-relaxed","children":"Welcome to the sukuna.site integration documentation. Here you will learn how to integrate our high-speed, secure redirect logic into your applications specifically to break users out of in-app browsers like Telegram."}],["$","h2",null,{"className":"text-2xl font-semibold mb-4 text-white border-b border-white/10 pb-2 flex items-center gap-2 mt-12","children":[["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-terminal w-5 h-5 text-blue-400","children":[["$","polyline","akl6gq",{"points":"4 17 10 11 4 5"}],["$","line","q2wloq",{"x1":"12","x2":"20","y1":"19","y2":"19"}],"$undefined"]}],"Telegram Bot Integration"]}],["$","p",null,{"className":"text-gray-400 mb-6","children":["If you are running a Telegram bot, you can easily implement the secure redirect by modifying your short URL generation logic. Our service expects a base64 encoded destination URL passed as the ",["$","code",null,{"children":"to"}]," query parameter."]}],["$","div",null,{"className":"mb-8 glass-card rounded-xl overflow-hidden border border-white/5","children":[["$","div",null,{"className":"bg-surface border-b border-white/5 px-4 py-3 flex items-center justify-between","children":[["$","span",null,{"className":"text-sm font-mono text-gray-300 flex items-center gap-2","children":[["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-code w-4 h-4","children":[["$","polyline","z7tu5w",{"points":"16 18 22 12 16 6"}],["$","polyline","1eg1df",{"points":"8 6 2 12 8 1