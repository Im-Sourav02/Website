ded destination URL passed as the ",["$","code",null,{"children":"to"}]," query parameter."]}],["$","div",null,{"className":"mb-8 glass-card rounded-xl overflow-hidden border border-white/5","children":[["$","div",null,{"className":"bg-surface border-b border-white/5 px-4 py-3 flex items-center justify-between","children":[["$","span",null,{"className":"text-sm font-mono text-gray-300 flex items-center gap-2","children":[["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-code w-4 h-4","children":[["$","polyline","z7tu5w",{"points":"16 18 22 12 16 6"}],["$","polyline","1eg1df",{"points":"8 6 2 12 8 18"}],"$undefined"]}]," config.py"]}],["$","span",null,{"className":"text-xs text-gray-500 uppercase font-bold tracking-wider","children":"Python"}]]}],["$","div",null,{"className":"p-4 bg-[#0d1117] overflow-x-auto text-sm","children":["$","pre",null,{"className":"text-blue-300 font-mono leading-relaxed","children":"# Define your Next.js redirect app URL\nREDIRECT_SERVICE_URL = \"https://sukuna.site/api/redirect\"\n"}]}]]}],["$","div",null,{"className":"mb-8 glass-card rounded-xl overflow-hidden border border-white/5","children":[["$","div",null,{"className":"bg-surface border-b border-white/5 px-4 py-3 flex items-center justify-between","children":[["$","span",null,{"className":"text-sm font-mono text-gray-300 flex items-center gap-2","children":[["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-code w-4 h-4","children":[["$","polyline","z7tu5w",{"points":"16 18 22 12 16 6"}],["$","polyline","1eg1df",{"points":"8 6 2 12 8 18"}],"$undefined"]}]," shorturl.py"]}],["$","span",null,{"className":"text-xs text-gray-500 uppercase font-bold tracking-wider","children":"Python"}]]}],["$","div",null,{"className":"p-4 bg-[#0d1117] overflow-x-auto text-sm","children":["$","pre",null,{"className":"text-gray-300 font-mono leading-relaxed","children":"import base64\nfrom config import REDIRECT_SERVICE_URL\nimport urllib.parse\n\ndef generate_secure_redirect(target_url: str) -> str:\n    \"\"\"\n    Generates a secure redirect URL for sukuna.site\n    which handles the Telegram in-app browser breakout.\n    \"\"\"\n    # Encode the destination URL in base64\n    encoded_bytes = base64.b64encode(target_url.encode(\"utf-8\"))\n    encoded_target = encoded_bytes.decode(\"utf-8\")\n    \n    # URL encode the base64 string just to be safe with query params\n    safe_target = urllib.parse.quote(encoded_target)\n    \n    # Construct the final URL\n    final_url = f\"{REDIRECT_SERVICE_URL}?to={safe_target}\"\n    \n    return final_url\n\n# Example Usage\nif __name__ == \"__main__\":\n    destination = \"https://example.com/secret-file-download\"\n    secure_link = generate_secure_redirect(destination)\n    print(f\"Send this link to users: {secure_link}\")\n"}]}]]}],"$L2"]}]]}],null,"$L3"]}],"loading":null,"isPartial":false}
